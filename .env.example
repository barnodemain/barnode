# BARnode — variabili d'ambiente (esempio, SENZA valori reali)
# Il .env reale NON va mai committato ed è generato dall'agent via App Control
# (cassaforte centrale delle variabili). Qui solo i nomi, per riferimento.

# --- Supabase (progetto BARnode) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # solo backend/script, MAI nel frontend
DATABASE_URL=
SUPABASE_DATABASE_URL=
SUPABASE_ACCESS_TOKEN=

# --- Deploy / repo ---
RENDER_API_KEY=
GITHUB_URL=
GITHUB_TOKEN=

# --- Frontend Vite (le uniche lette dal client, stessi valori Supabase) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ENABLE_SW=
